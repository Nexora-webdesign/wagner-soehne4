# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local build tools (not a runtime asset — used only to (re)encode the hero video)
public/ffmpeg.exe

# typescript
*.tsbuildinfo
next-env.d.ts
